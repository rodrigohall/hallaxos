# Copie para .env e ajuste se necessário. Os padrões funcionam com `pnpm dev`.
DATABASE_URL=postgres://hallax:hallax@localhost:5432/hallaxos
API_PORT=3333
COOKIE_SECURE=false
# Copiloto de IA (Sprint 9) — opcional. Deixe vazio para manter desligado (sem custo).
# Para ativar, gere uma chave da API da Anthropic e coloque aqui (nunca versione a chave real).
IA_API_KEY=
# Modelo padrão: Haiku 4.5 (barato/rápido). Troque por claude-sonnet-4-6 / claude-opus-4-8 se quiser.
# IA_MODELO=claude-haiku-4-5
